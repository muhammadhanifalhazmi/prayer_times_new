<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#00695C">

    <TextView
        android:id="@+id/widget_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Senin, 1 Januari 2024"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/widget_region"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Jakarta Selatan"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FFFFFF"
        android:alpha="0.3"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sholat Berikutnya"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/widget_prayer_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Subuh"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/widget_prayer_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="04:30"
        android:textColor="#FFD54F"
        android:textSize="32sp"
        android:gravity="center"
        android:fontFamily="sans-serif-black"/>

</LinearLayout>